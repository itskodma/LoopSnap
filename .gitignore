# ─── Swift Package Manager ────────────────────────────────────────────────────
.build/
.swiftpm/

# ─── Xcode ────────────────────────────────────────────────────────────────────
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# ─── Build outputs ────────────────────────────────────────────────────────────
*.o
*.d
*.dylib
*.a
build/
release/

# ─── .app bundles (generated by bundle_app.sh) ────────────────────────────────
*.app/

# ─── macOS metadata ───────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# ─── Instruments / Profiling ──────────────────────────────────────────────────
*.trace

# ─── Signing & provisioning ───────────────────────────────────────────────────
*.mobileprovision
*.provisionprofile
*.p12
*.cer
*.certSigningRequest
ExportOptions.plist

# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
secrets/

# ─── Editor configs ───────────────────────────────────────────────────────────
# Keep launch.json (useful for contributors) but ignore everything else VS Code generates
.vscode/*
!.vscode/launch.json
*.swp
*~
